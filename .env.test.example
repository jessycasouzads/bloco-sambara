# Plantilla para .env.test.local
# Copy a .env.test.local y completá con valores REALES del proyecto Supabase de TEST
# .env.test.local está gitignored — NUNCA commitees claves reales

# Project URL del proyecto Supabase de TEST (NO el de prod)
SUPABASE_TEST_URL=https://your-test-project-ref.supabase.co

# Anon key — la usan los tests al simular un usuario común
SUPABASE_TEST_ANON_KEY=your-test-anon-public-key

# Service role key — bypassa RLS. La usan los tests para setup/cleanup
# (crear tenants ficticios, crear/borrar users, limpiar entre tests).
# NUNCA exponer al cliente, NUNCA prefijar con VITE_, NUNCA commitear.
SUPABASE_TEST_SERVICE_ROLE_KEY=your-test-service-role-secret-key
